# Headers de sécurité et performance pour Netlify
# https://docs.netlify.com/routing/headers/

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(self), microphone=(), camera=()
  X-Frame-Options: SAMEORIGIN
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://unpkg.com https://uicdn.toast.com https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com https://unpkg.com https://uicdn.toast.com; font-src 'self' https://cdnjs.cloudflare.com https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://wqqsuybmyqemhojsamgq.supabase.co https://api-adresse.data.gouv.fr https://cartodb-basemaps-a.global.ssl.fastly.net https://cartodb-basemaps-b.global.ssl.fastly.net https://cartodb-basemaps-c.global.ssl.fastly.net https://cartodb-basemaps-d.global.ssl.fastly.net https://www.google-analytics.com https://www.googletagmanager.com; frame-src 'none'; base-uri 'self'; form-action 'self'

# Cache long pour assets statiques immuables (images, fonts)
/img/*
  Cache-Control: public, max-age=31536000, immutable

/img/logos/*
  Cache-Control: public, max-age=31536000, immutable

/img/cover/*
  Cache-Control: public, max-age=2592000

# Cache moyen pour CSS/JS (fichiers modifiés à chaque déploiement)
/styles/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/modules/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/*.css
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/*.js
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# Pages HTML : pas de cache (toujours servir la dernière version)
/*.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate


