# Headers de sécurité et performance pour Netlify
# https://docs.netlify.com/routing/headers/

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(self), microphone=(), camera=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  X-Frame-Options: SAMEORIGIN

# Cache long pour assets statiques immuables (images, fonts)
/img/*
  Cache-Control: public, max-age=31536000, immutable

/img/logos/*
  Cache-Control: public, max-age=31536000, immutable

/img/cover/*
  Cache-Control: public, max-age=2592000

# Cache immutable pour les assets Vite (hash dans le nom)
/home/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache moyen pour CSS/JS (fichiers modifiés à chaque déploiement)
/styles/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/modules/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/*.css
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/*.js
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# Pages HTML : pas de cache (toujours servir la dernière version)
/*.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate


